# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith (모니터링)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=mes-ai-agent

# MES Database
MES_DB_HOST=localhost
MES_DB_PORT=1521
MES_DB_NAME=MESDB
MES_DB_USER=mes_readonly
MES_DB_PASSWORD=your_db_password_here
MES_DB_TYPE=oracle   # oracle | mssql | postgresql

# Log System (Elasticsearch)
ES_ENABLED=false                    # true 로 변경하면 실제 ES 사용
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http                      # http | https
ES_USER=                            # X-Pack/보안 비활성화 시 공란
ES_PASSWORD=                        # X-Pack/보안 비활성화 시 공란
ES_INDEX_PATTERN=mes-logs-*         # 실제 인덱스 패턴으로 변경
LOG_MAX_SEARCH_RESULTS=50

# Source Code Repository (GitHub)
SOURCE_ENABLED=false                      # true 로 변경하면 실제 GitHub API 사용
GITHUB_TOKEN=your_github_pat_here        # Personal Access Token (code search 필수)
GITHUB_OWNER=your-org-or-username        # 조직 또는 사용자명
GITHUB_REPO=mes-backend                  # 저장소명
GITHUB_BRANCH=main                       # 기준 브랜치

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_SECONDS=3600

# Vector DB (ChromaDB)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=mes_knowledge

# Slack (에스컬레이션)
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_CHANNEL_MES_SUPPORT=#mes-support

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your_secret_key_here

# Agent Settings
MAX_CLARIFICATION_TURNS=2
ANSWER_CONFIDENCE_THRESHOLD=0.4
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LOG_SEARCH_WINDOW_MINUTES=60
